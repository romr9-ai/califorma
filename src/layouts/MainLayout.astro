---
import "../styles/global.css";
import { getUI, type Lang } from "../i18n/ui";
import WhatsAppButton from "../components/WhatsAppButton.astro";

interface Props {
	title?: string;
	description?: string;
	lang?: Lang;
}

const {
	title = "Califorma | Maquinado CNC de Precision",
	description = "Landing corporativa de Califorma para servicios de maquinado CNC, fabricacion de piezas y solicitud de cotizaciones.",
	lang = "es",
} = Astro.props;

const t = getUI(lang);
---

<!doctype html>
<html lang={t.meta.lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta property="og:locale" content={t.meta.locale} />
		<link rel="alternate" hreflang="es" href="/" />
		<link rel="alternate" hreflang="en" href="/en/" />
		<link rel="alternate" hreflang="x-default" href="/" />
		<title>{title}</title>
	</head>
	<body class="page-shell min-h-screen">
		<slot />
		<WhatsAppButton />
	</body>
</html>
