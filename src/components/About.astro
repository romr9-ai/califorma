---
import { getUI, type Lang } from "../i18n/ui";

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const ui = getUI(lang);
const t = ui.about;
const anchors = ui.anchors;
---

<section id={anchors.about} class="bg-slate-50">
	<div class="section-shell grid gap-14 lg:grid-cols-[0.88fr_1.12fr] lg:items-start">
		<div>
			<p class="eyebrow">{t.eyebrow}</p>
			<h2 class="section-title">{t.title}</h2>
			<div class="mt-8 hidden border-l border-slate-300 pl-6 lg:block">
				<p class="text-sm uppercase tracking-[0.24em] text-slate-500">{t.sideTitle}</p>
				<p class="mt-3 max-w-xs text-sm leading-7 text-slate-600">{t.sideDescription}</p>
			</div>
		</div>

		<div class="panel-light p-8 sm:p-10">
			<div class="max-w-3xl space-y-6 text-[1.02rem] leading-8 text-slate-600">
				{t.paragraphs.map((paragraph) => (
					<p>{paragraph}</p>
				))}
			</div>
			<div class="mt-10 grid gap-0 overflow-hidden rounded-[22px] border border-slate-200 sm:grid-cols-3">
				{t.metrics.map((metric, index) => (
					<div class:list={[
						"px-6 py-7",
						index === 0 && "bg-slate-950 text-white",
						index === 1 && "border-t border-slate-200 bg-slate-50 sm:border-l sm:border-t-0",
						index === 2 && "border-t border-slate-200 bg-white sm:border-l sm:border-t-0",
					]}>
						<p class:list={[
							"text-xs uppercase tracking-[0.24em]",
							index === 0 ? "text-orange-400" : "text-slate-500",
						]}>
							{metric.label}
						</p>
						<p class:list={[
							"mt-3 text-2xl font-semibold",
							index === 0 ? "text-white" : "text-slate-950",
						]}>
							{metric.value}
						</p>
					</div>
				))}
			</div>
		</div>
	</div>
</section>
