<section id="contacto" class="bg-slate-950 text-white">
	<div class="section-shell grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start lg:gap-14">
		<div class="lg:pt-4">
			<p class="eyebrow">Contacto</p>
			<h2 class="mt-5 max-w-xl text-3xl font-semibold tracking-[-0.03em] text-white sm:text-4xl lg:text-[2.8rem] lg:leading-[1.05]">
				Solicita tu cotizacion
			</h2>
			<p class="mt-4 max-w-xl text-base leading-7 text-slate-300">
				Cuentanos sobre tu proyecto y te responderemos lo antes posible.
			</p>
			<p class="mt-4 text-sm text-slate-400">
				Tambien puedes escribirnos a
				<a href="mailto:info@califorma.com.mx" class="font-medium text-orange-400 hover:text-orange-300">
					info@califorma.com.mx
				</a>
			</p>
			<div class="mt-10 grid gap-4 sm:grid-cols-2">
				<div class="rounded-2xl border border-white/10 bg-white/5 p-5">
					<p class="text-xs uppercase tracking-[0.22em] text-slate-400">Atencion</p>
					<p class="mt-3 text-lg font-semibold text-white">Respuesta enfocada a proyectos industriales</p>
				</div>
				<div class="rounded-2xl border border-white/10 bg-white/5 p-5">
					<p class="text-xs uppercase tracking-[0.22em] text-slate-400">Cobertura</p>
					<p class="mt-3 text-lg font-semibold text-white">Piezas, herramentales y procesos especiales</p>
				</div>
			</div>
		</div>

		<form class="rounded-[30px] border border-white/10 bg-[linear-gradient(180deg,rgba(255,255,255,0.08),rgba(255,255,255,0.04))] p-8 shadow-[0_30px_80px_-40px_rgba(0,0,0,0.8)] sm:p-10">
			<div class="grid gap-5 sm:grid-cols-2">
				<label class="block">
					<span class="mb-2 block text-sm font-medium text-slate-200">Nombre</span>
					<input
						type="text"
						placeholder="Tu nombre"
						class="w-full rounded-2xl border border-white/12 bg-slate-900/90 px-4 py-3.5 text-sm text-white outline-none transition placeholder:text-slate-500 focus:border-orange-400"
					/>
				</label>
				<label class="block">
					<span class="mb-2 block text-sm font-medium text-slate-200">Apellido</span>
					<input
						type="text"
						placeholder="Tu apellido"
						class="w-full rounded-2xl border border-white/12 bg-slate-900/90 px-4 py-3.5 text-sm text-white outline-none transition placeholder:text-slate-500 focus:border-orange-400"
					/>
				</label>
				<label class="block">
					<span class="mb-2 block text-sm font-medium text-slate-200">Email</span>
					<input
						type="email"
						placeholder="correo@empresa.com"
						class="w-full rounded-2xl border border-white/12 bg-slate-900/90 px-4 py-3.5 text-sm text-white outline-none transition placeholder:text-slate-500 focus:border-orange-400"
					/>
				</label>
				<label class="block">
					<span class="mb-2 block text-sm font-medium text-slate-200">Telefono</span>
					<input
						type="tel"
						placeholder="(000) 000 0000"
						class="w-full rounded-2xl border border-white/12 bg-slate-900/90 px-4 py-3.5 text-sm text-white outline-none transition placeholder:text-slate-500 focus:border-orange-400"
					/>
				</label>
			</div>
			<label class="mt-5 block">
				<span class="mb-2 block text-sm font-medium text-slate-200">Mensaje</span>
				<textarea
					rows="6"
					placeholder="Describe tu proyecto, materiales, cantidades o requerimientos."
					class="w-full rounded-2xl border border-white/12 bg-slate-900/90 px-4 py-3.5 text-sm text-white outline-none transition placeholder:text-slate-500 focus:border-orange-400"
				></textarea>
			</label>

			<button
				type="button"
				class="mt-7 inline-flex rounded-full bg-orange-500 px-7 py-3.5 text-sm font-semibold text-white shadow-[0_16px_40px_-18px_rgba(249,115,22,0.9)] transition hover:bg-orange-400"
			>
				Enviar solicitud
			</button>
		</form>
	</div>
</section>
