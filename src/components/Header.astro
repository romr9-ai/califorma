<header class="sticky top-0 z-50 border-b border-slate-800/60 bg-slate-950/80 backdrop-blur-xl">
	<div class="mx-auto flex max-w-[1280px] items-center justify-between px-6 py-4 lg:px-10">
		<a href="#inicio" class="text-xl font-semibold uppercase tracking-[0.22em] text-white">
			Califorma
		</a>

		<nav aria-label="Navegacion principal" class="hidden items-center gap-7 md:flex">
			<a href="#inicio" class="text-sm font-medium text-slate-300 transition hover:text-white">Inicio</a>
			<a href="#servicios" class="text-sm font-medium text-slate-300 transition hover:text-white">Servicios</a>
			<a href="#nosotros" class="text-sm font-medium text-slate-300 transition hover:text-white">Nosotros</a>
			<a href="#maquinaria" class="text-sm font-medium text-slate-300 transition hover:text-white">Maquinaria</a>
			<a href="#proyectos" class="text-sm font-medium text-slate-300 transition hover:text-white">Proyectos</a>
			<a
				href="#contacto"
				class="inline-flex items-center rounded-full border border-orange-400/70 bg-orange-500/12 px-5 py-2.5 text-sm font-semibold text-white shadow-[0_12px_30px_-18px_rgba(249,115,22,0.8)] transition hover:border-orange-400 hover:bg-orange-500"
			>
				Cotizar
			</a>
		</nav>

		<button
			type="button"
			class="inline-flex items-center justify-center rounded-full border border-slate-700 bg-slate-900/80 p-3 text-slate-200 transition hover:border-orange-400 hover:text-white md:hidden"
			aria-expanded="false"
			aria-controls="mobile-menu"
			aria-label="Abrir menu"
			data-menu-toggle
		>
			<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
				<path d="M4 7h16"></path>
				<path d="M4 12h16"></path>
				<path d="M4 17h16"></path>
			</svg>
		</button>
	</div>

	<div
		id="mobile-menu"
		class="hidden border-t border-slate-800/80 bg-slate-950/95 px-6 py-5 md:hidden"
		data-mobile-menu
	>
		<nav aria-label="Navegacion movil" class="flex flex-col gap-2">
			<a href="#inicio" class="rounded-2xl px-4 py-3 text-sm font-medium text-slate-200 transition hover:bg-slate-900 hover:text-white" data-mobile-link>Inicio</a>
			<a href="#servicios" class="rounded-2xl px-4 py-3 text-sm font-medium text-slate-200 transition hover:bg-slate-900 hover:text-white" data-mobile-link>Servicios</a>
			<a href="#nosotros" class="rounded-2xl px-4 py-3 text-sm font-medium text-slate-200 transition hover:bg-slate-900 hover:text-white" data-mobile-link>Nosotros</a>
			<a href="#maquinaria" class="rounded-2xl px-4 py-3 text-sm font-medium text-slate-200 transition hover:bg-slate-900 hover:text-white" data-mobile-link>Maquinaria</a>
			<a href="#proyectos" class="rounded-2xl px-4 py-3 text-sm font-medium text-slate-200 transition hover:bg-slate-900 hover:text-white" data-mobile-link>Proyectos</a>
			<a
				href="#contacto"
				class="mt-3 inline-flex items-center justify-center rounded-full border border-orange-400/70 bg-orange-500 px-5 py-3 text-sm font-semibold text-white shadow-[0_12px_30px_-18px_rgba(249,115,22,0.8)] transition hover:bg-orange-400"
				data-mobile-link
			>
				Cotizar
			</a>
		</nav>
	</div>
</header>

<script>
	const toggleButton = document.querySelector("[data-menu-toggle]");
	const mobileMenu = document.querySelector("[data-mobile-menu]");
	const mobileLinks = document.querySelectorAll("[data-mobile-link]");

	if (toggleButton instanceof HTMLButtonElement && mobileMenu instanceof HTMLElement) {
		const closeMenu = () => {
			mobileMenu.classList.add("hidden");
			toggleButton.setAttribute("aria-expanded", "false");
			toggleButton.setAttribute("aria-label", "Abrir menu");
		};

		const openMenu = () => {
			mobileMenu.classList.remove("hidden");
			toggleButton.setAttribute("aria-expanded", "true");
			toggleButton.setAttribute("aria-label", "Cerrar menu");
		};

		toggleButton.addEventListener("click", () => {
			const isOpen = !mobileMenu.classList.contains("hidden");
			if (isOpen) {
				closeMenu();
				return;
			}

			openMenu();
		});

		mobileLinks.forEach((link) => {
			link.addEventListener("click", () => {
				closeMenu();
			});
		});

		window.addEventListener("resize", () => {
			if (window.innerWidth >= 768) {
				closeMenu();
			}
		});
	}
</script>
