---
import { getUI, type Lang } from "../i18n/ui";

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const ui = getUI(lang);
const t = ui.hero;
const anchors = ui.anchors;
---

<section id={anchors.home} class="relative overflow-hidden">
	<div class="absolute inset-x-0 top-0 -z-10 h-[620px] bg-[linear-gradient(135deg,rgba(15,23,42,0.05),transparent_38%,rgba(249,115,22,0.06))]"></div>
	<div class="section-shell grid gap-14 lg:grid-cols-[1.02fr_0.98fr] lg:items-center lg:gap-10">
		<div class="pb-2 lg:pr-8">
			<p class="eyebrow">{t.eyebrow}</p>
			<h1 class="mt-7 max-w-4xl text-5xl font-semibold tracking-[-0.05em] text-slate-950 sm:text-6xl lg:text-[4.6rem] lg:leading-[0.94]">
				{t.title}
			</h1>
			<p class="mt-7 max-w-2xl text-lg leading-8 text-slate-600 lg:text-[1.15rem]">
				{t.description}
			</p>

			<div class="mt-10 flex flex-col gap-4 sm:flex-row sm:items-center">
				<a
					href={`#${anchors.contact}`}
					class="inline-flex items-center justify-center rounded-full bg-slate-950 px-7 py-3.5 text-sm font-semibold text-white shadow-[0_18px_50px_-24px_rgba(15,23,42,0.8)] transition hover:bg-slate-800"
				>
					{t.primaryCta}
				</a>
				<a
					href={`#${anchors.services}`}
					class="inline-flex items-center justify-center rounded-full border border-slate-300 bg-white/80 px-7 py-3.5 text-sm font-semibold text-slate-700 transition hover:border-slate-950 hover:text-slate-950"
				>
					{t.secondaryCta}
				</a>
			</div>
		</div>

		<div class="relative lg:pl-6">
			<div class="panel-dark relative overflow-hidden p-8 sm:p-10">
				<div class="absolute inset-0 bg-[linear-gradient(135deg,rgba(255,255,255,0.06),transparent_35%,rgba(249,115,22,0.08)_100%)]"></div>
				<div class="absolute inset-y-8 right-8 hidden w-px bg-white/10 lg:block"></div>
				<div class="relative grid gap-10 lg:grid-cols-[1.15fr_0.85fr] lg:items-end">
					<div>
						<p class="text-[0.72rem] font-semibold uppercase tracking-[0.3em] text-orange-400">
							{t.capacityLabel}
						</p>
						<p class="mt-5 max-w-md text-2xl font-semibold leading-tight text-white">
							{t.capacityTitle}
						</p>
						<p class="mt-5 max-w-md text-sm leading-7 text-slate-300">
							{t.capacityDescription}
						</p>
					</div>
					<div class="grid gap-4">
						<div class="rounded-2xl border border-white/10 bg-white/5 p-5">
							<p class="text-xs uppercase tracking-[0.24em] text-slate-400">{t.operationLabel}</p>
							<p class="mt-2 text-3xl font-semibold text-white">{t.operationValue}</p>
						</div>
						<div class="rounded-2xl border border-white/10 bg-white/5 p-5">
							<p class="text-xs uppercase tracking-[0.24em] text-slate-400">{t.scopeLabel}</p>
							<p class="mt-2 text-xl font-semibold text-white">{t.scopeValue}</p>
						</div>
					</div>
				</div>
			</div>
			<div class="mt-8 grid gap-4 px-4 sm:grid-cols-3 sm:px-6 lg:px-8">
				{t.highlights.map((highlight, index) => (
					<div class="panel-light p-5">
						<p class="text-xs font-semibold uppercase tracking-[0.22em] text-orange-600">
							{String(index + 1).padStart(2, "0")}
						</p>
						<h2 class="mt-4 text-lg font-semibold tracking-tight text-slate-950">{highlight}</h2>
					</div>
				))}
			</div>
		</div>
	</div>
</section>
