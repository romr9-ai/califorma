---
import { getUI, type Lang } from "../i18n/ui";

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const ui = getUI(lang);
const t = ui.hero;
const anchors = ui.anchors;
---

<section id={anchors.home} class="relative overflow-hidden">
	<div class="absolute inset-x-0 top-0 -z-10 h-[680px] bg-[linear-gradient(180deg,rgba(15,23,42,0.06),transparent_38%),linear-gradient(90deg,rgba(249,115,22,0.08),transparent_24%)]"></div>
	<div class="section-shell grid gap-10 lg:grid-cols-[0.88fr_1.12fr] lg:items-stretch lg:gap-0">
		<div class="flex flex-col justify-center border border-slate-800 bg-white px-8 py-12 shadow-[4px_4px_0px_0px_rgba(15,23,42,1)] sm:px-10 lg:min-h-[640px] lg:border-r-0 lg:px-12 lg:py-16">
			<p class="eyebrow">{t.eyebrow}</p>
			<h1 class="mt-7 max-w-4xl text-5xl font-semibold tracking-[-0.09em] text-slate-950 sm:text-6xl lg:text-[5.6rem] lg:leading-[0.88]">
				{t.title}
			</h1>
			<p class="mt-8 max-w-2xl text-lg leading-8 text-slate-600 lg:text-[1.08rem]">
				{t.description}
			</p>

			<div class="mt-10 flex flex-col gap-3 sm:flex-row sm:items-center">
				<a
					href={`#${anchors.contact}`}
					class="inline-flex items-center justify-center border border-slate-950 bg-slate-950 px-7 py-4 text-sm font-semibold uppercase tracking-[0.18em] text-white transition hover:bg-slate-800"
				>
					{t.primaryCta}
				</a>
				<a
					href={`#${anchors.services}`}
					class="inline-flex items-center justify-center border border-slate-800 bg-white px-7 py-4 text-sm font-semibold uppercase tracking-[0.18em] text-slate-700 transition hover:bg-slate-100 hover:text-slate-950"
				>
					{t.secondaryCta}
				</a>
			</div>
		</div>

		<div class="relative border border-slate-800 bg-slate-950 shadow-[4px_4px_0px_0px_rgba(15,23,42,1)] lg:min-h-[640px]">
			<img
				src="/assets/hero/hero.png"
				alt={t.title}
				class="absolute inset-0 h-full w-full object-cover object-center"
			/>
			<div class="absolute inset-0 bg-[linear-gradient(180deg,transparent_35%,rgba(15,23,42,0.28)_100%)]"></div>
			<div class="absolute inset-x-0 bottom-0 border-t border-slate-800 bg-slate-950/96 backdrop-blur-sm">
				<div class="grid sm:grid-cols-2">
					<div class="border-b border-slate-800 px-6 py-5 sm:border-b-0 sm:border-r">
						<p class="text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-slate-400">{t.operationLabel}</p>
						<p class="mt-2 text-2xl font-semibold tracking-tight text-white">{t.operationValue}</p>
					</div>
					<div class="px-6 py-5">
						<p class="text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-slate-400">{t.scopeLabel}</p>
						<p class="mt-2 text-lg font-semibold tracking-tight text-white">{t.scopeValue}</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
