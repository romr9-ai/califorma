---
import { getUI, type Lang } from "../i18n/ui";

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const ui = getUI(lang);
const t = ui.projects;
const anchors = ui.anchors;
---

<section id={anchors.projects} class="bg-slate-50">
	<div class="section-shell">
		<p class="eyebrow">{t.eyebrow}</p>
		<h2 class="section-title">{t.title}</h2>
		<p class="section-copy">{t.description}</p>

		<div class="mt-14 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
			{t.items.map((project) => (
				<article class="panel-light relative overflow-hidden p-0">
					<div class="absolute inset-x-0 top-0 h-1 bg-orange-500/80"></div>

					{project.video ? (
						<div class="group relative aspect-[16/10] overflow-hidden border-b border-slate-800 bg-slate-200">
							<img
								src={project.poster}
								alt={project.title}
								loading="lazy"
								class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.02] group-hover:opacity-0"
								onerror="this.parentElement?.classList.add('hidden'); this.closest('article')?.querySelector('[data-project-fallback]')?.classList.remove('hidden');"
							/>
							<video
								src={project.video}
								poster={project.poster}
								autoplay
								muted
								loop
								playsinline
								class="pointer-events-none absolute inset-0 h-full w-full object-cover opacity-0 transition duration-300 group-hover:opacity-100"
								onerror="this.parentElement?.classList.add('hidden'); this.closest('article')?.querySelector('[data-project-fallback]')?.classList.remove('hidden');"
							></video>
						</div>
					) : project.image ? (
						<div class="aspect-[16/10] overflow-hidden border-b border-slate-800 bg-slate-200">
							<img
								src={project.image}
								alt={project.title}
								loading="lazy"
								class="h-full w-full object-cover"
								onerror="this.parentElement?.classList.add('hidden'); this.closest('article')?.querySelector('[data-project-fallback]')?.classList.remove('hidden');"
							/>
						</div>
					) : null}

					<div
							class:list={[
							"project-media hidden aspect-[16/10] items-end overflow-hidden border-b border-slate-800 bg-[linear-gradient(135deg,#0f172a,#1e293b_58%,#f97316_180%)] p-6 text-white",
							!project.image && "flex",
						]}
						data-project-fallback
					>
							<div>
								<p class="text-[0.72rem] font-semibold uppercase tracking-[0.24em] text-orange-400">
									{t.itemLabel} {project.id}
								</p>
								<p class="mt-3 max-w-xs text-xl font-semibold leading-tight">{project.title}</p>
							</div>
					</div>

					<div class="p-7 sm:p-8">
						<p class="text-[0.72rem] font-semibold uppercase tracking-[0.24em] text-slate-500">
							{t.itemLabel} {project.id}
						</p>
						<h3 class="mt-5 text-2xl font-semibold tracking-tight text-slate-950">{project.title}</h3>
						<p class="mt-3 text-sm font-medium uppercase tracking-[0.18em] text-orange-600">
							{project.category}
						</p>
						<p class="mt-5 text-sm leading-7 text-slate-600">{project.description}</p>
					</div>
				</article>
			))}
		</div>
	</div>
</section>
