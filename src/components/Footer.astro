---
import { getUI, type Lang } from "../i18n/ui";

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const ui = getUI(lang);
const t = ui.footer;
const anchors = ui.anchors;
---

<footer class="border-t border-slate-200 bg-white">
	<div class="mx-auto flex max-w-[1280px] flex-col gap-6 px-6 py-10 text-sm text-slate-500 md:flex-row md:items-end md:justify-between lg:px-10">
		<div class="space-y-2">
			<p class="text-base font-semibold uppercase tracking-[0.18em] text-slate-950">{t.brand}</p>
			<p>{t.location}</p>
			<a href="mailto:info@califorma.com.mx" class="transition hover:text-slate-900">{t.email}</a>
		</div>
		<div class="flex gap-5">
			<a href={`#${anchors.home}`} class="transition hover:text-slate-900">{t.links.home}</a>
			<a href={`#${anchors.services}`} class="transition hover:text-slate-900">{t.links.services}</a>
			<a href={`#${anchors.contact}`} class="transition hover:text-slate-900">{t.links.contact}</a>
		</div>
	</div>
</footer>
