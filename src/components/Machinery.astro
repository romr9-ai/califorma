---
import { getUI, type Lang } from "../i18n/ui";

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const ui = getUI(lang);
const t = ui.machinery;
const anchors = ui.anchors;
---

<section id={anchors.machinery} class="bg-white">
	<div class="section-shell">
		<p class="eyebrow">{t.eyebrow}</p>
		<h2 class="section-title">{t.title}</h2>
		<p class="section-copy">{t.description}</p>

		<div class="mt-14 grid gap-6 md:grid-cols-2">
			{t.items.map((machine) => (
				<article
					class:list={[
						"group overflow-hidden rounded-[28px] border shadow-[0_24px_60px_-42px_rgba(15,23,42,0.35)]",
						machine.highlighted
							? "border-slate-800 bg-slate-950 text-white"
							: "border-slate-200/80 bg-white text-slate-950",
					]}
				>
					<div
						class:list={[
							"relative aspect-[16/10] overflow-hidden border-b border-black/10",
							machine.highlighted ? "bg-slate-900" : "bg-slate-100",
							machine.imageContainerClass,
						]}
					>
						<img
							src={machine.image}
							alt={machine.name}
							loading="lazy"
							class:list={[
								"absolute inset-0 h-full w-full transition duration-500 ease-out motion-reduce:transition-none",
								machine.imagePosition,
								machine.imageClass,
							]}
						/>
					</div>

					<div class:list={["relative p-8 sm:p-9", machine.highlighted && "overflow-hidden"]}>
						{machine.highlighted && (
							<div class="absolute inset-y-0 right-0 w-24 bg-[linear-gradient(180deg,rgba(249,115,22,0.15),transparent)]"></div>
						)}

						<p
							class:list={[
								"text-[0.7rem] font-bold uppercase tracking-[0.22em]",
								machine.highlighted ? "text-orange-400" : "text-orange-600",
							]}
						>
							{machine.type}
						</p>

						<h3 class="mt-5 text-2xl font-semibold tracking-tight">{machine.name}</h3>

						<div class="mt-8 grid grid-cols-2 gap-4">
							{machine.specs.map((spec) => (
								<div
									class:list={[
										"rounded-2xl border p-4",
										machine.highlighted
											? "border-slate-700 bg-slate-800/50"
											: "border-slate-200 bg-slate-50",
									]}
								>
									<p
										class:list={[
											"text-[0.65rem] uppercase tracking-[0.18em]",
											machine.highlighted ? "text-slate-400" : "text-slate-500",
										]}
									>
										{spec.label}
									</p>
									<p class="mt-2 text-lg font-semibold">{spec.value}</p>
								</div>
							))}
						</div>

						<p
							class:list={[
								"mt-6 text-sm leading-7",
								machine.highlighted ? "text-slate-300" : "text-slate-600",
							]}
						>
							{machine.description}
						</p>
					</div>
				</article>
			))}
		</div>
	</div>
</section>
