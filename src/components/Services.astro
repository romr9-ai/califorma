---
import { getUI, type Lang } from "../i18n/ui";

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const ui = getUI(lang);
const t = ui.services;
const anchors = ui.anchors;
---

<section id={anchors.services} class="bg-white">
	<div class="section-shell">
		<p class="eyebrow">{t.eyebrow}</p>
		<h2 class="section-title">{t.title}</h2>
		<p class="section-copy">{t.description}</p>

		<div class="mt-14 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
			{t.items.map((item, index) => (
				<article class:list={[
					"grid-card hover:-translate-y-1 hover:border-slate-300 hover:bg-slate-50",
					index === t.items.length - 1 && "md:col-span-2 xl:col-span-1",
				]}>
					<p class="text-[0.72rem] font-semibold uppercase tracking-[0.24em] text-orange-600">
						{`${t.itemLabel} ${String(index + 1).padStart(2, "0")}`}
					</p>
					<h3 class="mt-6 text-xl font-semibold tracking-tight text-slate-950">{item.title}</h3>
					<p class="mt-4 text-sm leading-7 text-slate-600">{item.description}</p>
				</article>
			))}
		</div>
	</div>
</section>
